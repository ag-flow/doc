# /data/.env — secrets d'environnement docflow (sur la VM, jamais committé)
# Copier vers /data/.env et remplir toutes les valeurs.

# ── Base de données ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://docflow:CHANGE_ME@postgres:5432/docflow

# ── Auth JWT ──────────────────────────────────────────────────────────────────
# Générer : python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_32_HEX_CHARS

# ── Bootstrap admin (break-glass) ─────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Harpocrate (résolution vault://) ──────────────────────────────────────────
# Laisser vide si secrets inline (dev uniquement)
# HARPOCRATE_URL=https://harpocrate.yoops.org

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
