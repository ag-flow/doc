# ══════════════════════════════════════════════════════════════════════════════
# docflow — configuration de production
# Copier ce fichier vers /data/.env et remplir toutes les valeurs marquées
# REQUIS. Ne jamais committer /data/.env dans git.
# ══════════════════════════════════════════════════════════════════════════════

# ── Base de données ────────────────────────────────────────────────────────────
# REQUIS. Format : postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Le mot de passe ici doit correspondre à celui de /data/pg_password.txt.
# Si postgres tourne dans le même compose : hôte = "postgres" (nom du service).
DATABASE_URL=postgresql://docflow:CHANGE_ME@postgres:5432/docflow

# ── Auth JWT ──────────────────────────────────────────────────────────────────
# REQUIS. Clé secrète pour signer les tokens JWT. Minimum 32 caractères hex.
# Générer : python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_64_HEX_CHARS

# ── Compte admin bootstrap (break-glass) ──────────────────────────────────────
# REQUIS. Créé au premier démarrage si absent. Toujours disponible même si
# l'OIDC est configuré (accès de secours). Ne pas supprimer ni désactiver
# si c'est le seul admin local.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Chiffrement (Fernet) ───────────────────────────────────────────────────────
# REQUIS dès que l'on utilise :
#   - des headers de webhooks (stockés chiffrés en base)
#   - les wallets Harpocrate (clés API chiffrées en base)
#   - les secrets utilisateur (valeurs chiffrées en base)
# Une fois positionné, NE PAS changer : les données chiffrées deviendraient
# illisibles. Sauvegarder cette valeur en lieu sûr.
# Générer : python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY

# ── Harpocrate (résolution vault://) ──────────────────────────────────────────
# OPTIONNEL. URL du service Harpocrate pour résoudre les références
# ${vault://wallet:/chemin} (headers d'automates, client_secret OIDC…).
# Laisser commenté si les secrets sont gérés en local (ENCRYPTION_KEY suffit).
# HARPOCRATE_URL=https://harpocrate.yoops.org

# ── Worker d'automates ─────────────────────────────────────────────────────────
# OPTIONNEL. Intervalle en secondes entre chaque tick du worker d'automates.
# Défaut : 60. Réduire pour des déclenchements plus réactifs.
# AUTOMATION_TICK_SECONDS=60

# ── Logging ───────────────────────────────────────────────────────────────────
# OPTIONNEL. Niveau de log : DEBUG | INFO | WARNING | ERROR. Défaut : INFO.
# Passer à DEBUG uniquement pour diagnostiquer un problème (verbeux).
LOG_LEVEL=INFO
